NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_CHAIN_ID=42220
# Use 8453 for Base mainnet or 42220 for Celo mainnet in local testing.

# Pinata IPFS Configuration
PINATA_JWT=your_pinata_jwt_token_here
# Get your JWT from: https://app.pinata.cloud/developers/api-keys
# Create a new API key with pinFileToIPFS permission

# Divvi Referral Tracking
NEXT_PUBLIC_DIVVI_CONSUMER=your_divvi_consumer_address
# Get from: https://divvi.app/
